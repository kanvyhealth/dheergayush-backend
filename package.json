  "main": "server.js",
  "scripts": {
    "test": "node --check server.js && node scripts/verify-auth-security.js",
    "test:auth": "node scripts/verify-auth-security.js",
    "test:razorpay": "node scripts/verify-razorpay-checkout.js",
    "check": "node --check server.js",
    "start": "node server.js",
    "db:migrate-firebase": "node scripts/migrateMongoToFirebase.js",
    "db:sync": "node scripts/syncStore.js",
