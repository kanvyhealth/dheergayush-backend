# Copy to .env — never commit .env

PORT=3000

# ── Firebase (auth + Firestore) — same project as the mobile app ───
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-web-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# Local: path to service account JSON
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# Render: paste minified JSON
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Production site URL (CORS, redirects)
SITE_URL=https://your-production-domain.com

# Admin dashboard
ADMIN_USERNAME=your-admin-user
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Agora video
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# Razorpay payments
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

NGROK_AUTHTOKEN=

# Rate limits (optional)
RATE_LIMIT_GLOBAL_MAX=2000
RATE_LIMIT_AUTH_MAX=40
RATE_LIMIT_WRITE_MAX=120
